# Revora Backend Environment Variables
# Copy this file to .env and fill in your values

# App Settings
APP_NAME=Revora
APP_ENV=development

# Security (REQUIRED)
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Generate JWT_SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Generate ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here
ENCRYPTION_KEY=your_fernet_key_here

# Database (REQUIRED)
DATABASE_URL=postgresql+asyncpg://revora:changeme@localhost:5432/revora_db

# Redis (optional)
# REDIS_URL=redis://localhost:6379/0

# GitHub OAuth (REQUIRED for login)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# GitHub App (REQUIRED for repository access)
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# LLM API Keys (at least one required)
GEMINI_API_KEY=your_gemini_api_key
# OPENAI_API_KEY=your_openai_api_key

# CORS (defaults to localhost:3000)
# CORS_ORIGINS=["http://localhost:3000"]
